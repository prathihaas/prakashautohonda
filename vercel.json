{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    { "source": "/sitemap.xml", "destination": "/sitemap-index.xml", "permanent": true },
    { "source": "/:path*", "has": [{"type": "host", "value": "prakashautohonda.com"}], "destination": "https://www.prakashautohonda.com/:path*", "permanent": true },
    { "source": "/login", "destination": "/", "permanent": true },
    { "source": "/register", "destination": "/", "permanent": true },
    { "source": "/my-account", "destination": "/", "permanent": true },
    { "source": "/team", "destination": "/", "permanent": true },
    { "source": "/team/:slug", "destination": "/", "permanent": true },
    { "source": "/listing/:slug", "destination": "/products/:slug", "permanent": true },
    { "source": "/search/:path*", "destination": "/products", "permanent": true },
    { "source": "/submit-listing", "destination": "/", "permanent": true },
    { "source": "/about-us", "destination": "/about", "permanent": true },
    { "source": "/contact-us", "destination": "/#branches", "permanent": true },
    { "source": "/contact", "destination": "/#branches", "permanent": true },
    { "source": "/vehicles/:slug", "destination": "/products/:slug", "permanent": true },
    { "source": "/motorcycle/:slug", "destination": "/products/:slug", "permanent": true },
    { "source": "/scooter/:slug", "destination": "/products/:slug", "permanent": true }
  ]
}
