---
// SEOHead.astro - Prakash Auto Honda
const {
  title = "Prakash Auto Honda | Authorized Honda Dealer in Kamareddy, Telangana",
  description = "Prakash Auto Honda is an authorized Honda two-wheeler dealership in Kamareddy, Telangana 503111. Explore Honda bikes & scooters, book test rides, and get genuine service.",
  canonical = Astro.url.href,
  image = "/og-image.jpg",
  ogType = "website",
  noOrgSchema = false,
} = Astro.props;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  "url": canonical,
  "name": title,
  "description": description,
  "inLanguage": "en-IN",
  "isPartOf": { "@id": "https://www.prakashautohonda.com/#organization" }
};

const schema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "@id": "https://www.prakashautohonda.com/#organization",
  "name": "Prakash Auto Honda",
  "url": "https://www.prakashautohonda.com",
  "logo": "https://www.prakashautohonda.com/logo.png",
  "image": "https://www.prakashautohonda.com/og-image.jpg",
  "description": "Authorized Honda two-wheeler dealership in Kamareddy, Telangana. New Honda bikes, scooters, service, and genuine spare parts.",
  "telephone": "+91-8886604615",
  "foundingDate": "2022",
  "brand": { "@type": "Brand", "name": "Honda" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hyderabad Road",
    "addressLocality": "Kamareddy",
    "addressRegion": "Telangana",
    "postalCode": "503111",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.3220, "longitude": 78.3404 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "areaServed": ["Kamareddy", "Banswada", "Yellareddy", "Nizamsagar", "Lingampet", "Bibipet", "Pitlam", "Tadwai", "Telangana"],
  "sameAs": [
    "https://www.facebook.com/prakashautohonda",
    "https://www.instagram.com/prakashautohonda"
  ]
};
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(image, Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:site_name" content="Prakash Auto Honda" />
<meta property="og:locale" content="en_IN" />
<meta property="og:locale:alternate" content="te_IN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

<!-- Geo Tags -->
<meta name="geo.region" content="IN-TG" />
<meta name="geo.placename" content="Kamareddy, Telangana" />
<meta name="geo.position" content="18.3220;78.3404" />
<meta name="ICBM" content="18.3220, 78.3404" />

<!-- Hreflang — signals English content with x-default fallback -->
<link rel="alternate" hreflang="en" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<!-- WebPage schema — on every page, links content to the organization entity -->
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
<!-- AutoDealer org schema — suppressed on product/article pages that define their own -->
{!noOrgSchema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
