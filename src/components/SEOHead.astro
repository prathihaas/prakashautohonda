---
// SEOHead.astro - Prakash Auto Honda
const {
  title = "Prakash Auto Honda | Authorized Honda Dealer in Kamareddy, Telangana",
  description = "Prakash Auto Honda is an authorized Honda dealership in Kamareddy, Telangana 503111. Explore new Honda cars, book test drives, and get genuine service.",
  canonical = Astro.url.href,
  image = "/og-image.jpg",
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Auto Honda",
  "url": "https://www.prakashautohonda.com",
  "logo": "https://www.prakashautohonda.com/logo.png",
  "image": "https://www.prakashautohonda.com/og-image.jpg",
  "description": "Authorized Honda dealership in Kamareddy, Telangana. New Honda two-wheelers, service, and genuine spare parts.",
  "telephone": "+91-8886604615",
  "brand": { "@type": "Brand", "name": "Honda" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Kamareddy Main Road",
    "addressLocality": "Kamareddy",
    "addressRegion": "Telangana",
    "postalCode": "503111",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.3220, "longitude": 78.3404 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "sameAs": [
    "https://www.facebook.com/prakashautohonda",
    "https://www.instagram.com/prakashautohonda"
  ]
};
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(image, Astro.site).toString()} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:site_name" content="Prakash Auto Honda" />
<meta property="og:locale" content="en_IN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

<!-- Geo Tags -->
<meta name="geo.region" content="IN-TG" />
<meta name="geo.placename" content="Kamareddy, Telangana" />
<meta name="geo.position" content="18.3220;78.3404" />
<meta name="ICBM" content="18.3220, 78.3404" />

<!-- JSON-LD Structured Data — set:html renders parsed JSON, not literal expression -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
