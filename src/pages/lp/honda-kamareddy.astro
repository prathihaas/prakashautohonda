  <!-- TRUST SIGNALS -->
  <section style="padding:28px 16px; max-width:600px; margin:0 auto;">
    <h2 style="font-size:17px; font-weight:900; text-align:center; margin-bottom:16px; color:#111;">Why Prakash Auto Honda?</h2>
