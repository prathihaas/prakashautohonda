        style="display:inline-flex; align-items:center; gap:6px; border:1.5px solid #25D366; color:#16A34A; padding:10px 20px; border-radius:10px; font-weight:700; font-size:13px;">
        💬 Not sure which model? Ask us →
      </a>
    </div>
  </section>

  <!-- EMI SECTION -->
  <section style="margin:0 16px 28px; max-width:568px; margin-left:auto; margin-right:auto; background:linear-gradient(135deg, #FFF1F2 0%, #FFF5F5 100%); border:1.5px solid #FECDD3; border-radius:16px; padding:24px 20px; text-align:center;">
