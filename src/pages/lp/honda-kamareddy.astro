  { name: "Honda Shine 125", price: "₹84,000 onwards", emi: "₹2,300/mo", icon: "🏍️", tag: "", waMsg: "Hi Prakash Auto Honda, I saw your ad. Please share today's best price for Honda Shine 125 in Kamareddy. [W-LP]" },
  { name: "Honda SP 160",    price: "₹1,18,000 onwards", emi: "₹3,200/mo", icon: "🏍️", tag: "Popular", waMsg: "Hi Prakash Auto Honda, I saw your ad. Please share today's best price for Honda SP 160 in Kamareddy. [W-LP]" },
