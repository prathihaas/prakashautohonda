      <a href={`${WA_BASE}${encodeURIComponent("Hi Prakash Auto Honda, I saw your ad and want today's best price on Honda bikes in Kamareddy. [W-LP]")}`}
        target="_blank" rel="noopener noreferrer" class="pulse"
        style="display:flex; align-items:center; justify-content:center; gap:10px; background:#25D366; color:white; padding:18px 20px; border-radius:14px; font-weight:900; font-size:18px;">
        💬 WhatsApp for Best Price
