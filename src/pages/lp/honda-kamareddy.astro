            <span style="font-size:28px;">{bike.icon}</span>
            <div>
              <p style="font-weight:800; font-size:15px; color:#111; line-height:1.2;">{bike.name}</p>
              <p style="font-size:12px; color:#DC2626; font-weight:700; margin-top:2px;">{bike.price}</p>
