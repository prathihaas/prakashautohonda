  { name: "Honda SP 125",    price: "₹96,000 onwards",  emi: "₹2,600/mo", icon: "🏍️", tag: "", waMsg: "Hi Prakash Auto Honda, I saw your ad. Please share today's best price for Honda SP 125 in Kamareddy. [W-LP]" },
  { name: "Honda Hornet 2.0", price: "₹1,35,000 onwards", emi: "₹3,700/mo", icon: "🏍️", tag: "", waMsg: "Hi Prakash Auto Honda, I saw your ad. Please share today's best price for Honda Hornet 2.0 in Kamareddy. [W-LP]" },
];

const branches = [
  { name: "Kamareddy (Main)", phone: "8886680259" },
  { name: "Lingampet",        phone: "9985033315" },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the on-road price of Honda Activa 125 in Kamareddy?", "acceptedAnswer": { "@type": "Answer", "text": "Honda Activa 125 on-road price in Kamareddy starts from ₹95,000. Contact Prakash Auto Honda on 8886604615 for today's exact price including taxes, insurance and registration." }},
    { "@type": "Question", "name": "Where is the nearest Honda showroom in Kamareddy?", "acceptedAnswer": { "@type": "Answer", "text": "Prakash Auto Honda has 2 showrooms — Kamareddy (main) and Lingampet. Call 8886604615 to find the nearest one." }},
    { "@type": "Question", "name": "Does Prakash Auto Honda offer EMI for Honda bikes?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. EMI starts from ₹2,600/month with zero down payment on select models. Instant approval through multiple finance partners including HDFC Bank, SBI and Bajaj Finance." }},
    { "@type": "Question", "name": "Can I book a test ride at Prakash Auto Honda Kamareddy?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, free test rides are available at both branches — Kamareddy and Lingampet. WhatsApp 8886604615 to book your slot in advance." }},
    { "@type": "Question", "name": "Does Prakash Auto Honda accept old bike exchange?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, we offer exchange bonus up to ₹5,000 this month. Bring your old bike for a free valuation at any branch." }},
  ]
};

const localSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Auto Honda Kamareddy",
  "telephone": "+91-8886604615",
  "url": "https://www.prakashautohonda.com/lp/honda-kamareddy",
  "address": { "@type": "PostalAddress", "streetAddress": "Main Road", "addressLocality": "Kamareddy", "addressRegion": "Telangana", "postalCode": "503111", "addressCountry": "IN" },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.3194, "longitude": 78.3376 },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.3", "reviewCount": "500", "bestRating": "5" },
  "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "09:00", "closes": "19:00" }]
};
---

<!doctype html>
<html lang="en">
<head>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-KL6X6MMB');</script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta name="theme-color" content="#DC2626" />
  <meta name="geo.region" content="IN-TG" />
  <meta name="geo.placename" content="Kamareddy, Telangana" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(localSchema)} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Noto+Sans+Telugu:wght@400;500;700&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #fff; color: #111; -webkit-tap-highlight-color: transparent; }
    .fn { font-family: 'Noto Sans Telugu', sans-serif; }
    a { text-decoration: none; }

    /* Sticky bar height reservation */
    .page-body { padding-bottom: 80px; }

    /* Pulse animation for primary WhatsApp CTA */
    @keyframes pulse-green {
      0%, 100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
      50%       { box-shadow: 0 0 0 10px rgba(37, 211, 102, 0); }
    }
    .pulse { animation: pulse-green 2s infinite; }

    /* Urgency badge flash */
    @keyframes flash {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.6; }
    }
    .flash { animation: flash 1.8s ease-in-out infinite; }

    /* Bike card tap feedback */
    .bike-card { transition: border-color 0.15s, box-shadow 0.15s; }
    .bike-card:active { transform: scale(0.98); }
  </style>
</head>
<body>
<!-- GTM noscript -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KL6X6MMB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div class="page-body">

  <!-- HEADER — logo + call button, zero nav links -->
  <header style="background:#DC2626; padding:10px 16px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50;">
    <div style="display:flex; align-items:center; gap:8px;">
      <span style="font-size:22px;">🏍️</span>
      <div>
        <p style="color:white; font-weight:900; font-size:16px; line-height:1;">Prakash Auto Honda</p>
        <p style="color:#fca5a5; font-size:10px; line-height:1; margin-top:2px;">Authorized Honda Dealer · Kamareddy</p>
      </div>
    </div>
    <a href={PHONE} style="background:white; color:#DC2626; font-weight:800; font-size:13px; padding:8px 14px; border-radius:8px; display:flex; align-items:center; gap:5px;">
      📞 {PHONE_DISPLAY}
    </a>
  </header>

  <!-- URGENCY BANNER -->
  <div style="background:#FEF3C7; border-bottom:1px solid #FCD34D; padding:8px 16px; text-align:center;">
    <p class="flash" style="font-size:13px; font-weight:700; color:#92400E;">
      🔥 Limited Time Offer — Exchange Bonus Up to ₹5,000 This Month Only
    </p>
  </div>

  <!-- HERO -->
  <section style="background:linear-gradient(160deg, #fff 60%, #fff5f5 100%); padding:28px 16px 24px; text-align:center; max-width:600px; margin:0 auto;">

    <div style="display:inline-flex; align-items:center; gap:6px; background:#DCFCE7; color:#166534; font-size:11px; font-weight:700; padding:4px 12px; border-radius:20px; margin-bottom:14px;">
      ✅ Authorized Honda Dealer · Kamareddy · Telangana
    </div>

    <h1 style="font-size:clamp(24px,6vw,32px); font-weight:900; line-height:1.15; color:#111; margin-bottom:8px;">
      Honda Bikes Best Price<br/>
      <span style="color:#DC2626;">Kamareddy</span>
    </h1>

    <p class="fn" style="color:#6B7280; font-size:14px; margin-bottom:6px;">
      కామారెడ్డిలో హోండా బైక్స్ — అత్యుత్తమ ధర
    </p>
    <p style="font-size:13px; color:#6B7280; margin-bottom:20px;">
      2 Branches · Easy EMI · Test Ride Available · Same-Day Delivery
    </p>

    <!-- Social proof row -->
    <div style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-bottom:24px;">
      <div style="text-align:center;">
        <p style="font-size:20px; font-weight:900; color:#DC2626; line-height:1;">4.3★</p>
        <p style="font-size:10px; color:#9CA3AF;">Google Rating</p>
      </div>
      <div style="width:1px; background:#E5E7EB;"></div>
      <div style="text-align:center;">
