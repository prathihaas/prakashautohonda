---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Honda Bike Guides & Buying Tips | Prakash Auto Honda Kamareddy" description="Expert Honda buying guides, bike comparisons and local advice from Prakash Auto Honda — your authorized Honda dealer in Kamareddy, Telangana.">
  <main class="max-w-7xl mx-auto px-4 py-16 pt-28">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-black text-gray-900 mb-2">Honda Guides & Tips</h1>
      <p class="text-gray-400 mt-3 max-w-xl mx-auto">Buying guides, bike comparisons and riding tips from Prakash Auto Honda experts in Kamareddy.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map(post => (
        <a href={`/blog/${post.slug}`} class="group bg-white rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col">
          <div class="aspect-video bg-gray-100 overflow-hidden">
            {post.data.featured_image
              ? <img src={post.data.featured_image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              : <div class="w-full h-full flex items-center justify-center bg-red-50"><span class="text-red-300 text-4xl font-black">H</span></div>
            }
          </div>
          <div class="p-6 flex flex-col flex-grow">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-bold uppercase tracking-wide">{post.data.category}</span>
              {post.data.readTime && <span class="text-xs text-gray-400">{post.data.readTime}</span>}
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600 transition leading-snug flex-grow">{post.data.title}</h3>
            <p class="text-sm text-gray-500 line-clamp-2 mb-4">{post.data.excerpt}</p>
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-auto">
              {post.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
            </span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>
