---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title, title_te, seo_title, seo_description,
  featured_image, excerpt, category, readTime, author, tags,
  date,
} = entry.data;

const displayDate = date.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": seo_title || title,
  "description": seo_description || excerpt,
  "image": featured_image || "https://www.prakashautohonda.com/og-image.jpg",
  "author": { "@type": "Person", "name": author || "Prakash Auto Honda Team" },
  "publisher": {
    "@type": "Organization",
    "name": "Prakash Auto Honda",
    "logo": { "@type": "ImageObject", "url": "https://www.prakashautohonda.com/logo.png" }
  },
  "datePublished": date.toISOString(),
  "dateModified": date.toISOString(),
  "url": Astro.url.href,
  "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url.href }
};
---

<Layout title={seo_title} description={seo_description} image={featured_image}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <nav class="pt-24 pb-2 max-w-3xl mx-auto px-4">
    <div class="flex items-center gap-2 text-xs text-gray-400 font-semibold uppercase tracking-wider">
      <a href="/" class="hover:text-red-600 transition">Home</a>
      <span>/</span>
      <a href="/blog" class="hover:text-red-600 transition">Blog</a>
      <span>/</span>
      <span class="text-gray-600">{category}</span>
    </div>
  </nav>

  <article class="pb-24 bg-white">
    <div class="max-w-3xl mx-auto px-4">

      <header class="text-center py-10">
        <div class="flex items-center justify-center gap-3 mb-5">
          <span class="inline-block bg-red-50 text-red-600 font-bold tracking-widest uppercase text-xs px-3 py-1 rounded-full">
            {category}
          </span>
          {readTime && <span class="text-xs text-gray-400 font-semibold">{readTime}</span>}
        </div>
        <h1 class="text-3xl md:text-5xl font-black text-gray-900 mb-4 leading-tight">{title}</h1>
        {title_te && <h2 class="text-xl text-gray-400 font-noto mb-4">{title_te}</h2>}
        <p class="text-lg text-gray-500 leading-relaxed">{excerpt}</p>
        <div class="flex justify-center gap-6 mt-6 text-sm text-gray-400 font-semibold">
          <span>{displayDate}</span>
          {author && <span>By {author}</span>}
        </div>
      </header>

      {featured_image && (
        <img src={featured_image} alt={title} class="w-full aspect-video object-cover rounded-2xl shadow-lg mb-10" loading="eager" />
      )}

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {tags.map(tag => (
            <span class="text-xs bg-red-50 text-red-600 px-3 py-1 rounded-full font-semibold">{tag}</span>
          ))}
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-red
        prose-headings:font-black prose-headings:text-gray-900
        prose-a:text-red-600 prose-a:font-bold
        prose-strong:text-gray-900
        prose-img:rounded-xl
        prose-table:w-full prose-th:bg-red-600 prose-th:text-white prose-th:p-3 prose-td:p-3 prose-td:border">
        <Content />
      </div>

      <div class="mt-16 pt-10 border-t border-gray-100 text-center rounded-2xl bg-red-50 p-8">
        <h3 class="font-black text-gray-900 text-2xl mb-2">Ready to take a test ride?</h3>
        <p class="text-gray-500 mb-6">Visit Prakash Auto Honda in Kamareddy — your local Honda expert</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/918886604615?text=Hi%2C%20I%20read%20your%20blog%20and%20want%20to%20know%20more%20about%20Honda%20bikes.%20%5BW-PA%5D" target="_blank"
             class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded-full font-bold shadow hover:bg-green-600 transition">
            WhatsApp Us
          </a>
          <a href="tel:+918886604615"
             class="inline-flex items-center gap-2 bg-red-600 text-white px-6 py-3 rounded-full font-bold shadow hover:bg-red-700 transition">
            Call Now
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>
