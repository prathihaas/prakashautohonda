---
import Layout from '../layouts/Layout.astro';

const title = "Prakash Auto Honda Kamareddy | Authorized Honda Showroom & Service Centre";
const description = "Visit Prakash Auto Honda showroom in Kamareddy, Telangana. Authorized Honda two-wheeler dealer — buy Activa, Shine, Unicorn, SP 125. Call +91-8886604615.";

const locationSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Auto Honda — Kamareddy Showroom",
  "url": "https://www.prakashautohonda.com/kamareddy",
  "telephone": "+91-8886604615",
  "brand": { "@type": "Brand", "name": "Honda" },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Kamareddy Main Road",
    "addressLocality": "Kamareddy",
    "addressRegion": "Telangana",
    "postalCode": "503111",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.3220, "longitude": 78.3404 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "parentOrganization": {
    "@type": "AutoDealer",
    "name": "Prakash Auto Honda",
    "url": "https://www.prakashautohonda.com"
  }
};
---

<Layout title={title} description={description}>

  <!-- Location-specific JSON-LD schema -->
  <script type="application/ld+json" set:html={JSON.stringify(locationSchema)} />

  <main class="pt-24 pb-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Page Header -->
      <div class="mb-12">
        <a href="/" class="inline-flex items-center gap-2 text-red-600 font-semibold mb-6 hover:text-red-700 transition text-sm">
          ← Back to Home
        </a>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight text-gray-900 mb-3">
          Prakash Auto Honda — Kamareddy Showroom
        </h1>
        <h2 class="font-noto text-2xl font-bold text-gray-500 mb-4">
          ప్రకాష్ ఆటో హోండా — కామారెడ్డి షోరూమ్
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl">
          Authorized Honda two-wheeler dealership in Kamareddy, Telangana. Test ride the latest Honda Activa, Shine, Unicorn and more. Genuine service, easy EMI financing available.
        </p>
      </div>

      <!-- Contact Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">

        <a href="tel:+918886604615"
          class="group bg-red-600 p-8 rounded-2xl text-center hover:bg-red-700 transition-all duration-300 transform hover:-translate-y-1 shadow-lg">
          <div class="w-12 h-12 mx-auto bg-white/20 text-white rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <p class="font-bold text-lg text-white">Call Now</p>
          <p class="text-white/80 text-sm mt-1">+91 88866 04615</p>
          <p class="font-noto text-white/60 text-xs mt-1">ఇప్పుడే కాల్ చేయండి</p>
        </a>

        <a href="https://wa.me/918886604615?text=Hi%2C%20I%20want%20to%20visit%20Prakash%20Auto%20Honda%20Kamareddy%20showroom.%20%5BW-PA%5D"
          target="_blank" rel="noopener noreferrer"
          class="group bg-white border-2 border-gray-200 p-8 rounded-2xl text-center hover:border-green-400 hover:bg-green-50 transition-all duration-300 transform hover:-translate-y-1 shadow-sm">
          <p class="font-bold text-lg text-gray-800">WhatsApp</p>
          <p class="text-gray-500 text-sm mt-1">+91 88866 04615</p>
          <p class="font-noto text-gray-400 text-xs mt-1">వాట్సాప్ పంపండి</p>
        </a>

        <a href="https://www.google.com/maps/search/Prakash+Auto+Honda+Kamareddy"
          target="_blank" rel="noopener noreferrer"
          class="group bg-white border-2 border-gray-200 p-8 rounded-2xl text-center hover:border-red-300 hover:bg-red-50 transition-all duration-300 transform hover:-translate-y-1 shadow-sm">
          <p class="font-bold text-lg text-gray-800">Get Directions</p>
          <p class="text-gray-500 text-sm mt-1">Open Google Maps</p>
          <p class="font-noto text-gray-400 text-xs mt-1">దారి చూపించండి</p>
        </a>

      </div>

      <!-- Address + Hours -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
          <h2 class="text-lg font-black text-gray-900 uppercase tracking-wide mb-4">Showroom Address</h2>
          <p class="font-bold text-gray-800">Prakash Auto Honda</p>
          <p class="text-gray-600 mt-1">Kamareddy Main Road,</p>
          <p class="text-gray-600">Kamareddy, Telangana – 503111</p>
          <p class="font-noto text-gray-500 mt-3">కామారెడ్డి మెయిన్ రోడ్,</p>
          <p class="font-noto text-gray-500">కామారెడ్డి, తెలంగాణ – 503111</p>
        </div>
        <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
          <h2 class="text-lg font-black text-gray-900 uppercase tracking-wide mb-4">Working Hours</h2>
          <div class="space-y-3 text-gray-700">
            <div class="flex justify-between">
              <span class="font-medium">Mon – Sat</span>
              <span class="font-bold text-red-600">9:00 AM – 7:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="font-medium">Sunday</span>
              <span class="text-gray-400">Closed</span>
            </div>
          </div>
          <p class="font-noto text-gray-500 mt-4 text-sm">సోమ – శని: ఉదయం 9 – సాయంత్రం 7</p>
        </div>
      </div>

      <!-- Nearby Areas served -->
      <div class="bg-gray-50 rounded-2xl p-8 mb-12 border border-gray-100">
        <h2 class="text-xl font-black text-gray-900 mb-4">Serving Kamareddy District &amp; Nearby Areas</h2>
        <p class="text-gray-600 mb-4">Prakash Auto Honda serves Honda customers across Kamareddy district including:</p>
        <div class="flex flex-wrap gap-2">
          {['Kamareddy', 'Yellareddy', 'Banswada', 'Nizamsagar', 'Pitlam', 'Domakonda', 'Bichkunda', 'Sadasivanagar', 'Bhiknoor', 'Machareddy'].map(area => (
            <span class="bg-white border border-gray-200 text-gray-700 px-3 py-1 rounded-full text-sm font-medium">{area}</span>
          ))}
        </div>
      </div>

      <!-- Honda Products CTA -->
      <div class="bg-red-600 rounded-2xl p-10 text-center text-white">
        <h2 class="text-2xl font-black mb-2">Explore Honda Bikes &amp; Scooters</h2>
        <p class="font-noto text-lg font-bold text-white/70 mb-4">హోండా బైక్స్ &amp; స్కూటర్లు చూడండి</p>
        <p class="text-white/80 max-w-lg mx-auto mb-8">Full range available at our Kamareddy showroom — Honda Activa, Shine, SP 125, Unicorn, Hornet and more.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/products" class="bg-white text-red-600 font-black px-8 py-3 rounded-xl hover:bg-gray-100 transition uppercase tracking-wide">View All Models</a>
          <a href="https://wa.me/918886604615?text=Hi%2C%20I%20want%20to%20book%20a%20test%20ride%20at%20Prakash%20Auto%20Honda%20Kamareddy.%20%5BW-PA%5D" target="_blank" class="bg-white/10 text-white font-bold px-8 py-3 rounded-xl hover:bg-white/20 transition border border-white/30">Book a Test Ride</a>
        </div>
      </div>

    </div>
  </main>

</Layout>
