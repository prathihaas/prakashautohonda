---
import { getEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';

const homePage = await getEntry('pages', 'home');
const products = await getCollection('products');
const branches = await getCollection('branches');

if (!homePage) throw new Error("Could not find 'home' entry in 'pages' collection.");

const { title_te, description_en, description_te, seo_title, seo_description, hero_image } = homePage.data;

const WA = "https://wa.me/918886604615";
const PHONE = "tel:+918886604615";

// LocalBusiness schema with both branches
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Auto Honda",
  "url": "https://www.prakashautohonda.com",
  "logo": "https://www.prakashautohonda.com/favicon.png",
  "telephone": "+91-8886604615",
  "description": "Authorized Honda two-wheeler dealer in Kamareddy, Telangana with 2 branches.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Kamareddy",
    "addressLocality": "Kamareddy",
    "addressRegion": "Telangana",
    "postalCode": "503111",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 18.3236, "longitude": 78.3428 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:00"
  }],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.3",
    "reviewCount": "500",
    "bestRating": "5"
  },
  "brand": { "@type": "Brand", "name": "Honda" },
  "areaServed": ["Kamareddy", "Lingampet", "Banswada", "Nizamabad", "Telangana"],
  "sameAs": ["https://www.facebook.com/prakashautohonda"],
  "department": [
    {
      "@type": "AutoDealer",
      "name": "Prakash Auto Honda — Kamareddy",
      "telephone": "+91-8886680259",
      "address": { "@type": "PostalAddress", "streetAddress": "Kamareddy", "addressLocality": "Kamareddy", "addressRegion": "Telangana", "postalCode": "503111", "addressCountry": "IN" },
      "url": "https://www.prakashautohonda.com"
    },
    {
      "@type": "AutoDealer",
      "name": "Prakash Auto Honda — Lingampet",
      "telephone": "+91-9985033315",
      "address": { "@type": "PostalAddress", "streetAddress": "Main Road, Lingampetpet", "addressLocality": "Lingampet", "addressRegion": "Telangana", "addressCountry": "IN" },
      "url": "https://www.prakashautohonda.com"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Where is Prakash Auto Honda showroom in Kamareddy?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Auto Honda main showroom is located in Kamareddy, Telangana 503111. We also have a branch in Lingampet. Call 8886604615 for directions." }
    },
    {
      "@type": "Question",
      "name": "What is the price of Honda Activa 125 in Kamareddy?",
      "acceptedAnswer": { "@type": "Answer", "text": "Honda Activa 125 on-road price in Kamareddy starts from ₹95,000 onwards. Contact Prakash Auto Honda on 8886604615 for today's best offer and EMI options." }
    },
    {
      "@type": "Question",
      "name": "Does Prakash Auto Honda offer EMI for Honda bikes?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, Prakash Auto Honda offers easy EMI options starting from ₹2,100/month for Honda bikes and scooters through multiple finance partners." }
    },
    {
      "@type": "Question",
      "name": "What are Prakash Auto Honda showroom timings?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Auto Honda is open Monday to Saturday, 9 AM to 7 PM. Both Kamareddy and Lingampet branches follow the same timings." }
    },
    {
      "@type": "Question",
      "name": "Which Honda bikes are available at Prakash Auto Honda Kamareddy?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Auto Honda Kamareddy has the full Honda range — Activa 125, Activa 110, Shine 125, Shine 100, SP 125, SP 160, Unicorn, Dio 110, Dio 125, Livo, Hornet 2.0, CB Hornet 125, and CB200X." }
    },
    {
      "@type": "Question",
      "name": "How to book a Honda test ride in Kamareddy?",
      "acceptedAnswer": { "@type": "Answer", "text": "You can book a free test ride at Prakash Auto Honda Kamareddy by calling 8886604615 or WhatsApp at wa.me/918886604615. Test rides are available Monday to Saturday." }
    }
  ]
};
---

<Layout title={seo_title} description={seo_description}>

  <!-- Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO SECTION — Conversion focused -->
  <div class="relative pt-28 pb-10 md:pt-40 md:pb-16 overflow-hidden bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-4xl mx-auto">

        <a href={PHONE} class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-100 text-red-700 mb-4 hover:bg-red-200 transition">
          <span class="text-xs font-bold uppercase tracking-wider">✓ Authorized Honda Dealer — Kamareddy</span>
        </a>

        <!-- SEO H1 targeting "Honda Showroom Kamareddy" -->
        <h1 class="text-4xl md:text-5xl font-black tracking-tight text-gray-900 mb-3 leading-tight">
          Honda Showroom Kamareddy<br/>
          <span class="text-red-600">— Best Price, Test Ride & EMI</span>
        </h1>
        <p class="text-lg text-gray-500 font-noto mb-2">{title_te}</p>
        <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto mb-2">{description_en}</p>
        <p class="text-sm text-gray-500 font-noto mb-8">{description_te}</p>

        <!-- PRIMARY CTAs: Call + WhatsApp above fold -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-4">
          <a href={PHONE}
            class="flex items-center justify-center gap-3 bg-red-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-red-700 transition shadow-lg shadow-red-200 active:scale-95">
            📞 Call Now — 8886604615
          </a>
          <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Auto Honda, I want to know today's best offer on Honda bikes in Kamareddy. [W-HP]")}`}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 bg-green-600 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-green-700 transition shadow-lg shadow-green-200 active:scale-95">
            💬 WhatsApp for Best Price
          </a>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-4">
          <a href="/products" class="inline-flex items-center gap-2 text-gray-700 border border-gray-200 px-6 py-3 rounded-xl hover:border-red-300 hover:bg-red-50 font-semibold transition text-sm">
            🏍️ View All Honda Models
          </a>
          <a href="#branches" class="inline-flex items-center gap-2 text-gray-700 border border-gray-200 px-6 py-3 rounded-xl hover:border-red-300 hover:bg-red-50 font-semibold transition text-sm">
            📍 Find Showroom
          </a>
        </div>

        <!-- Social proof -->
        <div class="flex items-center justify-center gap-6 mt-4 text-sm text-gray-500 flex-wrap">
          <a href="https://www.google.com/search?q=Prakash+Auto+Honda+Kamareddy+reviews" target="_blank" rel="noopener noreferrer" class="hover:text-red-600 transition">⭐ 4.3/5 Rating</a>
          <span>•</span>
          <a href="https://www.google.com/search?q=Prakash+Auto+Honda+Kamareddy+reviews" target="_blank" rel="noopener noreferrer" class="hover:text-red-600 transition">👥 500+ Happy Customers</a>
          <span>•</span>
          <a href="#branches" class="hover:text-red-600 transition">🏪 2 Branches</a>
          <span>•</span>
          <a href={PHONE} class="hover:text-red-600 transition">✅ Honda Authorized</a>
        </div>
      </div>

      <div class="mt-10 relative">
        <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent z-10 h-full w-full"></div>
        <img
          src={hero_image}
          alt="Honda Showroom Kamareddy — Prakash Auto Honda"
          class="rounded-2xl shadow-2xl w-full object-cover h-64 md:h-[460px] grayscale-[10%]"
        />
      </div>
    </div>
  </div>

  <!-- EMI HIGHLIGHT STRIP -->
  <div class="bg-red-600 text-white py-4">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-center gap-4 text-center sm:text-left">
      <p class="font-bold text-lg">🎯 Honda Activa EMI from ₹2,100/month</p>
      <span class="hidden sm:block text-red-200">|</span>
      <p class="text-sm text-red-100">Zero down payment on select models · Instant Approval</p>
      <a href={`${WA}?text=${encodeURIComponent("Hi, I want to know about Honda EMI options in Kamareddy. [W-EMI]")}`}
        target="_blank" rel="noopener noreferrer"
        class="bg-white text-red-600 px-5 py-2 rounded-lg font-bold text-sm hover:bg-red-50 transition whitespace-nowrap">
        Check EMI →
      </a>
    </div>
  </div>

  <!-- TRUST FEATURES -->
  <div class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: "🏆", en: "Authorized Dealer", te: "అధీకృత డీలర్", href: PHONE, external: false },
          { icon: "🔧", en: "Expert Service",    te: "నిపుణుల సర్వీస్", href: "/service", external: false },
          { icon: "💰", en: "Easy EMI",          te: "సులభ EMI", href: `${WA}?text=${encodeURIComponent("Hi, I want to know about Honda EMI options in Kamareddy. [W-EMI]")}`, external: true },
          { icon: "📍", en: "2 Branches",        te: "2 శాఖలు", href: "#branches", external: false },
        ].map(f => (
          <a href={f.href} target={f.external ? "_blank" : undefined} rel={f.external ? "noopener noreferrer" : undefined} class="flex flex-col items-center text-center p-5 rounded-2xl bg-gray-50 border border-gray-100 hover:border-red-200 hover:bg-red-50 transition">
            <div class="text-2xl mb-2">{f.icon}</div>
            <p class="font-bold text-gray-900 text-sm">{f.en}</p>
            <p class="text-xs text-gray-500 font-noto mt-1">{f.te}</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- PRODUCT GRID -->
  <div class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-10 gap-3">
        <div>
          <h2 class="text-3xl font-black text-gray-900">Honda Bikes & Scooters in Kamareddy</h2>
          <p class="font-noto text-gray-500 mt-1">కామారెడ్డిలో హోండా బైక్స్ మరియు స్కూటర్లు</p>
        </div>
        <a href="/products" class="text-red-600 font-bold hover:underline text-sm whitespace-nowrap">View All Models →</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <ProductCard
            title_en={product.data.name_en}
            title_te={product.data.name_te}
            price={product.data.price}
            mileage={product.data.mileage || 'N/A'}
            image={product.data.featured_image || ''}
            slug={product.slug}
            category={product.data.category}
          />
        ))}
      </div>

      <!-- Internal product links -->
      <div class="mt-10 p-6 bg-white rounded-2xl border border-gray-100">
        <p class="font-bold text-gray-700 mb-4 text-sm">Popular Models at <a href="/" class="text-red-600 hover:underline">Honda Showroom Kamareddy</a>:</p>
        <div class="flex flex-wrap gap-2">
          {[
            {slug:"activa-125", name:"Honda Activa 125 Kamareddy"},
            {slug:"activa-110", name:"Honda Activa 110"},
            {slug:"shine-125",  name:"Honda Shine 125"},
            {slug:"sp-160",     name:"Honda SP 160"},
            {slug:"unicorn",    name:"Honda Unicorn"},
            {slug:"dio-125",    name:"Honda Dio 125"},
            {slug:"sp-125",     name:"Honda SP 125"},
            {slug:"hornet-2-0", name:"Honda Hornet 2.0"},
          ].map(b => (
            <a href={`/products/${b.slug}`} class="text-xs text-red-600 bg-red-50 px-3 py-1 rounded-full hover:bg-red-100 font-semibold transition">
              {b.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- SERVICE SECTION -->
  <div class="py-20 bg-gray-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-red-600 opacity-10 rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-red-500 font-bold tracking-wider uppercase text-sm">Service & Support</span>
          <h2 class="text-4xl font-bold mt-2 mb-2">Expert Honda Service in Kamareddy</h2>
          <h3 class="text-xl text-gray-400 font-noto font-medium mb-6">కామారెడ్డిలో హోండా సర్వీసింగ్</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-center gap-3"><span class="text-red-500">✓</span> Genuine Honda Spare Parts</li>
            <li class="flex items-center gap-3"><span class="text-red-500">✓</span> Honda-Trained Technicians</li>
            <li class="flex items-center gap-3"><span class="text-red-500">✓</span> Service at Both Branches</li>
            <li class="flex items-center gap-3"><span class="text-red-500">✓</span> Online Service Booking via WhatsApp</li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href={`${WA}?text=${encodeURIComponent("Hi, I want to book a service for my Honda in Kamareddy. [W-SVC]")}`}
              target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-green-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-green-700 transition">
              💬 Book Service via WhatsApp
            </a>
            <a href={PHONE} class="inline-flex items-center justify-center gap-2 border border-gray-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-800 transition">
              📞 Call for Service
            </a>
          </div>
        </div>
        <div>
          <img src="https://yashhonda.com/wp-content/uploads/2020/05/workshop-min-1024x382-1.png"
            alt="Honda Service Center Kamareddy — Prakash Auto Honda"
            class="rounded-2xl shadow-2xl border border-gray-700 opacity-90" />
        </div>
      </div>
    </div>
  </div>

  <!-- BRANCHES SECTION — dead clicks FIXED, each card wrapped in <a> -->
  <div class="py-16 bg-white" id="branches">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-black text-gray-900">Honda Showrooms Near You</h2>
        <p class="font-noto text-gray-500 mt-2 mb-1">కామారెడ్డిలో మా షోరూమ్‌లు</p>
        <p class="text-sm text-gray-400">2 branches — Kamareddy & Lingampet</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        {branches.map((branch) => (
          <div class="group bg-white rounded-2xl border border-gray-200 p-6 hover:border-red-300 hover:shadow-lg transition-all duration-200">
            <div class="flex items-start justify-between mb-3">
              <div>
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-red-600 transition">{branch.data.name_en}</h3>
                <p class="text-sm text-gray-500 font-noto">{branch.data.name_te}</p>
              </div>
              <span class="text-red-500 text-lg">📍</span>
            </div>

            <p class="text-gray-600 text-sm leading-relaxed mb-1">{branch.data.address_en}</p>
            <p class="text-xs text-gray-400 font-noto mb-3">{branch.data.address_te}</p>

            <div class="flex items-center gap-2 mb-5">
              <span class="text-xs text-gray-500">📞</span>
              <a href={`tel:${branch.data.phone.replace(/\s/g, '')}`} class="font-bold text-gray-900 text-sm hover:text-red-600 transition">{branch.data.phone}</a>
              <span class="text-xs text-gray-400 ml-auto">Mon–Sat, 9AM–7PM</span>
            </div>

            <!-- 3 action buttons — each is its own link, no dead click parent div -->
            <div class="grid grid-cols-3 gap-2">
              <a href={`tel:${branch.data.phone.replace(/\s/g, '')}`}
                class="flex items-center justify-center gap-1 bg-red-600 text-white rounded-lg py-2 font-bold text-xs hover:bg-red-700 transition">
                📞 Call
              </a>
              <a href={branch.data.map_link} target="_blank" rel="noopener noreferrer"
                class="flex items-center justify-center gap-1 border border-gray-200 rounded-lg py-2 font-semibold text-xs hover:bg-gray-50 transition text-gray-700">
                🗺️ Directions
              </a>
              <a href={`${WA}?text=${encodeURIComponent(`Hi, I want to visit Prakash Auto Honda ${branch.data.name_en}. [W-BR]`)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center justify-center gap-1 bg-green-50 text-green-700 border border-green-200 rounded-lg py-2 font-bold text-xs hover:bg-green-100 transition">
                💬 WhatsApp
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 text-center">
        <p class="text-sm text-gray-500 mb-3">Find your nearest Honda showroom:</p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/" class="text-xs text-red-600 bg-red-50 px-3 py-1 rounded-full hover:bg-red-100 font-semibold transition">Honda Showroom Kamareddy</a>
          <a href="/" class="text-xs text-red-600 bg-red-50 px-3 py-1 rounded-full hover:bg-red-100 font-semibold transition">Honda Showroom Lingampet</a>
        </div>
      </div>
    </div>
  </div>

  <!-- REVIEWS SECTION -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoDealer",
    "name": "Prakash Auto Honda",
    "url": "https://www.prakashautohonda.com",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.3",
      "reviewCount": "500",
      "bestRating": "5",
      "worstRating": "1"
    }
  })} />

  <section class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-black text-gray-900 mb-1">What Our Customers Say</h2>
        <p class="font-noto text-lg text-gray-500 mb-4">మా కస్టమర్ల అభిప్రాయాలు</p>
        <div class="flex items-center justify-center gap-3 mb-1">
          <span class="text-yellow-400 text-2xl">★★★★</span><span class="text-yellow-300 text-2xl">★</span>
          <span class="text-4xl font-black text-gray-900">4.3</span>
          <span class="text-gray-500 text-base">/ 5 &nbsp;·&nbsp; <strong class="text-gray-700">500+ reviews</strong></span>
        </div>
        <p class="text-gray-500 text-sm">Trusted Honda dealer in <strong>Kamareddy</strong> & <strong>Lingampet</strong></p>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 mb-8">
        {[
          { name: "Suresh K",       stars: 5, text: "Excellent service at Prakash Auto Honda. Got my Activa 125 at the best price with easy EMI. Highly recommended!" },
          { name: "Ravi Shankar",   stars: 5, text: "Very helpful staff. The process was smooth and they explained all the finance options clearly. Happy with my SP 125." },
          { name: "Priya Reddy",    stars: 5, text: "Best Honda showroom in Kamareddy. Got a great deal on Dio 125 with zero down payment. Great experience." },
          { name: "Mahesh Yadav",   stars: 4, text: "Good service and genuine parts. My Unicorn has been serviced here multiple times and always runs perfectly." },
        ].map(r => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
            <div class="text-yellow-400 text-lg mb-2">{"★".repeat(r.stars)}</div>
            <p class="text-gray-700 text-sm leading-relaxed mb-4">"{r.text}"</p>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-red-600 text-white text-xs flex items-center justify-center font-bold">{r.name[0]}</div>
              <span class="text-sm font-semibold text-gray-700">{r.name}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.google.com/maps/search/Prakash+Auto+Honda+Kamareddy" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-white border-2 border-gray-200 text-gray-800 px-8 py-4 rounded-xl font-bold hover:border-red-300 hover:bg-red-50 transition shadow-sm">
          Read All Google Reviews
        </a>
        <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Auto Honda, I'd like to know today's best offer. [W-HP]")}`}
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition shadow-lg">
          💬 Get Today's Best Price
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION — visible on page for users + crawlers -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-black text-gray-900 mb-2 text-center">Frequently Asked Questions</h2>
      <p class="font-noto text-gray-500 text-center mb-10">తరచుగా అడిగే ప్రశ్నలు</p>
      <div class="space-y-4">
        {[
          { q: "Where is Prakash Auto Honda in Kamareddy?",        a: "Prakash Auto Honda is located in Kamareddy, Telangana 503111. We also have a branch in Lingampet. Call 8886604615 for exact directions." },
          { q: "What is Honda Activa 125 price in Kamareddy?",     a: "Honda Activa 125 on-road price in Kamareddy starts from ₹95,000. Call 8886604615 or WhatsApp for today's best offer." },
